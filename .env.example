# LINE Channel (from LINE Developers Console)
LINE_CHANNEL_ACCESS_TOKEN=paste_your_long_token_here
LINE_CHANNEL_SECRET=paste_your_secret_here

# Firebase Service Account (paste whole JSON contents on ONE line)
# Get from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# Port (Render fills in automatically — leave blank in production)
PORT=3000
